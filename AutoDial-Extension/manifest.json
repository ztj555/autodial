{
  "manifest_version": 3,
  "name": "AutoDial",
  "version": "3.1.0",
  "description": "一键拨号 - CRM客户手机号自动拨打",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://guwen.zhudaicms.com/*",
    "*://*.zhudaicms.com/*",
    "*://*.rxhcrm.com/*",
    "*://*.rongxinhui.com/*",
    "http://127.0.0.1:35432/*",
    "http://127.0.0.1:35441/*",
    "http://*:35441/*",
    "https://*:35441/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://guwen.zhudaicms.com/*",
        "*://*.zhudaicms.com/*",
        "*://*.rxhcrm.com/*",
        "*://*.rongxinhui.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
