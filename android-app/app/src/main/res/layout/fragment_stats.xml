<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:tag="bg"
    android:background="#888888"
    android:orientation="vertical"
    android:paddingStart="2dp"
    android:paddingTop="0dp"
    android:paddingEnd="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:tag="topBar"
        android:background="#888888"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的财库"
            android:drawableStart="@drawable/ic_ph_chart_bar"
            android:drawablePadding="9dp"
            android:tag="primaryLight"
            android:textColor="#888888"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:tag="bg2"
                    android:background="#888888"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日拨号(财运)"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTodayCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0次"
                        android:textColor="#FF4444"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/statsTodayConnect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:tag="text2"
                        android:text="接通 0 · 0%"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:tag="bg2"
                    android:background="#888888"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日通时(财气)"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTodayDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0.0分"
                        android:textColor="#8E44AD"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:id="@+id/statsWeekCallCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:tag="bg2"
                    android:background="#888888"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="13dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/statsWeekCallLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="一周拨号(财运)"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0次"
                        android:tag="text"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/statsWeekConnect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:tag="text2"
                        android:text="接通 0 · 0%"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statsWeekDurationCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:tag="bg2"
                    android:background="#888888"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="13dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/statsWeekDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="一周通时(财气)"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTotalDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0.0分"
                        android:tag="text"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:tag="bg2"
                android:background="#888888"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/statsMonthCallCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/statsMonthCallLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本月财运"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTodayLuck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0次"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/statsMonthConnect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:tag="text2"
                        android:text="接通 0 · 0%"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="72dp"
                    android:background="#22262F"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:id="@+id/statsMonthDurationCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/statsMonthDurationLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本月财气"
                        android:tag="text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/statsTotalLuck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </LinearLayout>

            <!-- 上门统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:tag="bg2"
                android:background="#888888"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="上门统计"
                        android:drawableStart="@drawable/ic_ph_chart_bar"
                        android:drawablePadding="6dp"
                        android:tag="primaryLight"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/statsVisitSyncBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="同步"
                        android:drawableStart="@drawable/ic_ph_arrows_clockwise"
                        android:drawablePadding="5dp"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_primary_btn"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisitToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="本周"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisitWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="近7天"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisit7Days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22262F"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="当月"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisitMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="上月"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisitLastMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="近30天"
                            android:tag="text2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/statsVisit30Days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:tag="text"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/statsLuckHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="成功通话 +1 财运，每分钟 +1 财气"
                android:tag="text2"
                android:textColor="#888888"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#4F8EF7"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="近 7 天趋势"
                    android:tag="text"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/statsChartContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:tag="bg2"
                android:background="#888888"
                android:gravity="bottom|center_horizontal"
                android:orientation="horizontal"
                android:padding="16dp"
                android:paddingBottom="0dp" />

            <LinearLayout
                android:id="@+id/statsDateLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:tag="bg2"
                android:background="#888888"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
