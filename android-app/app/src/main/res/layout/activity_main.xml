<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:tag="bg"
    android:background="#111318"
    android:paddingStart="14dp"
    android:paddingTop="8dp"
    android:paddingEnd="14dp"
    android:paddingBottom="8dp">

    <!-- ViewPager2 容器 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <!-- 底部导航栏：通话 | 录上门 | 统计 | 设置 -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        android:tag="navBar"
        android:background="@drawable/bg_v3_nav"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 通话 -->
        <LinearLayout
            android:id="@+id/tabCallLog"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/tabCallLogIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ph_list_numbers" />

            <TextView
                android:id="@+id/tabCallLogLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="通话"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 录上门 -->
        <LinearLayout
            android:id="@+id/tabRegister"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/tabRegisterIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ph_note_pencil" />

            <TextView
                android:id="@+id/tabRegisterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="录上门"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 统计 -->
        <LinearLayout
            android:id="@+id/tabStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/tabStatsIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ph_chart_bar" />

            <TextView
                android:id="@+id/tabStatsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="财库"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 设置 -->
        <LinearLayout
            android:id="@+id/tabConnect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/tabConnectIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_settings" />

            <TextView
                android:id="@+id/tabConnectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="设置"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 底部安全区域 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:tag="divider"
        android:background="#111318" />

</LinearLayout>
