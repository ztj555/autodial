<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:tag="bg"
    android:background="#111318">

    <!-- ViewPager2 容器 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 底部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:tag="bg2"
        android:background="#1A1D24"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 连接/设置 -->
        <LinearLayout
            android:id="@+id/tabConnect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔗"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tabConnectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="设置"
                android:tag="goldLight"
                android:textColor="#F0C040"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 通话记录 -->
        <LinearLayout
            android:id="@+id/tabCallLog"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tabCallLogLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="记录"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 统计 -->
        <LinearLayout
            android:id="@+id/tabStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tabStatsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="统计"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 底部安全区域 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:tag="divider"
        android:background="#111318" />

</LinearLayout>
