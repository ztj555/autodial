<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:tag="bg2"
        android:background="#111318"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <!-- 彩色状态条：绿=接通 灰=未接 红=失败 -->
        <View
            android:id="@+id/itemStatusBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp" />

        <!-- 左侧：号码行（号码+卡标签横排）+ 时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 号码 + 卡标签 横排 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/itemCallNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="138****8888"
                    android:tag="text"
                    android:textColor="#E8DCC8"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- 卡标签，紧跟号码后面 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:tag="chip"
                    android:background="#22262F"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="3dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_ph_sim_card" />

                    <TextView
                        android:id="@+id/itemSimSlot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="卡1"
                        android:textColor="#C9A84C"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 时间 -->
            <TextView
                android:id="@+id/itemCallTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="04-25 17:30"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 右侧：通话状态（接通Xs / 未接通 / 来电X秒） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="vertical">

            <!-- 通话类型：图标+文字 -->
            <TextView
                android:id="@+id/itemCallType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:drawablePadding="4dp"
                android:textSize="16sp"
                android:textColor="#42C077" />

            <!-- 通话状态文字 -->
            <TextView
                android:id="@+id/itemCallStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="end"
                android:text="接通 12s"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:tag="divider"
        android:background="#2A3040"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="4dp" />

</LinearLayout>
