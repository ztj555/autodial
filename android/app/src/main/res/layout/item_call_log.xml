<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:tag="bg"
        android:background="#111318"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- 左侧：号码行（号码+卡标签横排）+ 时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 号码 + 卡标签 横排 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/itemCallNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="138****8888"
                    android:tag="text"
                    android:textColor="#E8DCC8"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- 卡标签，紧跟号码后面 -->
                <TextView
                    android:id="@+id/itemSimSlot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:tag="bg3"
                    android:background="#22262F"
                    android:paddingStart="10dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="3dp"
                    android:text="卡1"
                    android:textColor="#C9A84C"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 时间 -->
            <TextView
                android:id="@+id/itemCallTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="04-25 17:30"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 右侧：通话状态（接通Xs / 未接通 / 来电X秒） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="vertical">

            <!-- 通话类型图标 -->
            <TextView
                android:id="@+id/itemCallType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="📞"
                android:textSize="18sp" />

            <!-- 通话状态文字 -->
            <TextView
                android:id="@+id/itemCallStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="end"
                android:text="接通 12s"
                android:tag="text2"
                android:textColor="#A09070"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:tag="divider"
        android:background="#22262F"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

</LinearLayout>
